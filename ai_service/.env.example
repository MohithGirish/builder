# ─── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=info

# ─── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ─── Internal auth (shared secret with Node backend) ───────────────────────────
INTERNAL_API_KEY=replace_with_strong_shared_secret
